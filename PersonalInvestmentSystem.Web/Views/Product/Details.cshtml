@model PersonalInvestmentSystem.Web.Domain.Entities.InvestmentProduct
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <!-- Phần hình ảnh & thông tin cơ bản -->
        <div class="col-lg-5">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Name" style="width:100%; height:380px; object-fit:cover;" />
            }
            else
            {
                <div class="bg-light border rounded d-flex align-items-center justify-content-center" style="height:380px;">
                    <h1 class="text-muted">No Image</h1>
                </div>
            }
        </div>

        <!-- Phần thông tin chi tiết -->
        <div class="col-lg-7">
            <h2>@Model.Name <span class="text-muted fs-5">(@Model.Code)</span></h2>

            <div class="d-flex align-items-center gap-3 mb-3">
                <h3 class="text-primary mb-0">@Model.CurrentPrice.ToString("N0") ₫</h3>
                <span class="badge bg-@(Model.ChangePercent >= 0 ? "success" : "danger") fs-6">
                    @(Model.ChangePercent >= 0 ? "+" : "")@Model.ChangePercent%
                </span>
                <span class="badge bg-@(Model.RiskLevel == PersonalInvestmentSystem.Web.Domain.Enums.RiskLevel.Low ? "success" :
                                      Model.RiskLevel == PersonalInvestmentSystem.Web.Domain.Enums.RiskLevel.Medium ? "warning" : "danger")">
                    Rủi ro: @Model.RiskLevel
                </span>
            </div>

            <p class="lead">@Model.Description</p>

            <div class="row mb-4">
                <div class="col-md-6">
                    <strong>Loại sản phẩm:</strong> @Model.Type<br />
                    <strong>Nhà phát hành:</strong> @Model.Publisher?.Name<br />
                    <strong>Danh mục:</strong> @Model.Category?.Name
                </div>
                <div class="col-md-6">
                    <strong>Giá trước đó:</strong> @Model.PreviousPrice.ToString("N0") ₫<br />
                    <strong>Trạng thái:</strong> @(Model.IsActive ? "Đang giao dịch" : "Tạm ngừng")
                </div>
            </div>

            <!-- Nút hành động -->
            <div class="d-grid gap-2 d-md-flex">
                <button class="btn btn-success btn-lg px-5" onclick="buyProduct(@Model.Id)">MUA NGAY</button>
                <button class="btn btn-outline-danger btn-lg px-5" onclick="sellProduct(@Model.Id)">BÁN</button>
                <button class="btn btn-outline-primary btn-lg px-4" onclick="addToWishlist(@Model.Id)">
                    <i class="fas fa-heart"></i> Yêu thích
                </button>
            </div>
        </div>
    </div>

    <!-- Biểu đồ giá -->
    <div class="mt-5">
        <h4>Biểu đồ biến động giá 7 ngày gần nhất</h4>
        <canvas id="priceChart" height="120"></canvas>
    </div>

    <!-- Tab thông tin thêm (mô tả, đánh giá...) -->
    <div class="mt-5">
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#description">Mô tả</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#reviews">Đánh giá</button>
            </li>
        </ul>
        <div class="tab-content mt-3">
            <div class="tab-pane fade show active" id="description">
                <p>@Model.Description</p>
                <p class="text-muted">Thông tin chi tiết sẽ được cập nhật đầy đủ trong phiên bản sau...</p>
            </div>
            <div class="tab-pane fade" id="reviews">
                <p>Chức năng đánh giá sản phẩm sẽ được triển khai ở bước sau.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function buyProduct(id) {
            if (confirm('Xác nhận MUA sản phẩm này?')) {
                var form = document.createElement('form');
                form.method = 'POST';
                form.action = '/Transaction/Buy';

                var input1 = document.createElement('input');
                input1.type = 'hidden';
                input1.name = 'productId';
                input1.value = id;
                form.appendChild(input1);

                document.body.appendChild(form);
                form.submit();
            }
        }

        function sellProduct(id) {
            var qty = prompt('Nhập số lượng muôn bán:', '1');
            if (qty && parseInt(qty) > 0) {
                var form = document.createElement('form');
                form.method = 'POST';
                form.action = '/Transaction/Sell';

                var input1 = document.createElement('input');
                input1.type = 'hidden';
                input1.name = 'productId';
                input1.value = id;
                form.appendChild(input1);

                var input2 = document.createElement('input');
                input2.type = 'hidden';
                input2.name = 'quantity';
                input2.value = qty;
                form.appendChild(input2);

                document.body.appendChild(form);
                form.submit();
            }
        }

        function addToWishlist(id) {
            alert('Thêm vào danh sách yêu thích thành công!');
        }

        // Khởi tạo biểu đồ giá 7 ngày
        document.addEventListener('DOMContentLoaded', function() {
            var priceHistory = @Html.Raw(Json.Serialize(ViewBag.PriceHistory));
            
            if (priceHistory && priceHistory.length > 0) {
                var labels = priceHistory.map(function(item) { return item.Date || item.date; });
                var prices = priceHistory.map(function(item) { return item.Price || item.price; });
                
                var ctx = document.getElementById('priceChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Giá (₫)',
                            data: prices,
                            borderColor: '#007bff',
                            backgroundColor: 'rgba(0, 123, 255, 0.1)',
                            borderWidth: 2,
                            tension: 0.1,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                display: true,
                                position: 'top'
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: false,
                                ticks: {
                                    callback: function(value) {
                                        return value.toLocaleString('vi-VN') + ' ₫';
                                    }
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}