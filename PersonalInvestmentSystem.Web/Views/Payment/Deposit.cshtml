@{
    ViewData["Title"] = "Nạp tiền vào ví";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4><i class="fas fa-wallet"></i> Nạp tiền vào Ví InvestPro</h4>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <h5>
                            Số dư hiện tại:
                            <span class="text-success fw-bold">
                                @(ViewBag.CurrentBalance != null ? ((decimal)ViewBag.CurrentBalance).ToString("N0") : "0") ₫
                            </span>
                        </h5>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Chọn số tiền nạp</label>
                        <div class="row g-3">
                            <div class="col-6 col-md-4">
                                <button type="button" class="btn btn-outline-primary w-100 amount-btn" data-amount="50000">50.000 ₫</button>
                            </div>
                            <div class="col-6 col-md-4">
                                <button type="button" class="btn btn-outline-primary w-100 amount-btn" data-amount="100000">100.000 ₫</button>
                            </div>
                            <div class="col-6 col-md-4">
                                <button type="button" class="btn btn-outline-primary w-100 amount-btn" data-amount="200000">200.000 ₫</button>
                            </div>
                            <div class="col-6 col-md-4">
                                <button type="button" class="btn btn-outline-primary w-100 amount-btn" data-amount="500000">500.000 ₫</button>
                            </div>
                            <div class="col-6 col-md-4">
                                <button type="button" class="btn btn-outline-primary w-100 amount-btn" data-amount="1000000">1.000.000 ₫</button>
                            </div>
                            <div class="col-6 col-md-4">
                                <button type="button" class="btn btn-outline-primary w-100 amount-btn" data-amount="5000000">5.000.000 ₫</button>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Hoặc nhập số tiền khác</label>
                        <div class="input-group">
                            <input type="number" id="customAmount" class="form-control" placeholder="Nhập số tiền" min="10000" step="1000" />
                            <span class="input-group-text">₫</span>
                        </div>
                    </div>

                    <button type="button" onclick="submitMoMoPayment()" class="btn btn-success btn-lg w-100">
                        <i class="fas fa-credit-card"></i> Thanh toán qua MoMo
                    </button>
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-controller="Wallet" asp-action="Index" class="btn btn-outline-secondary">← Quay lại Ví của tôi</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý chọn số tiền nhanh
        document.querySelectorAll('.amount-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const amount = this.getAttribute('data-amount');
                document.getElementById('customAmount').value = amount;

                // Highlight nút được chọn
                document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('btn-primary'));
                this.classList.add('btn-primary');
            });
        });

        // Hàm submit MoMo
        function submitMoMoPayment() {
            let amountStr = document.getElementById('customAmount').value.trim();
            let amount = parseFloat(amountStr);

            if (!amount || amount < 10000) {
                alert("Vui lòng chọn hoặc nhập số tiền nạp tối thiểu 10.000 ₫");
                return;
            }

            // Tạo form động và submit (để tránh postback bình thường)
            var form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Payment/CreateMoMoPayment';

            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'amount';
            input.value = amount;
            form.appendChild(input);

            document.body.appendChild(form);
            form.submit();
        }
    </script>
}