@model IEnumerable<PersonalInvestmentSystem.Web.Domain.Entities.WatchList>
@{
    ViewData["Title"] = "Danh sách Yêu thích";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2><i class="fas fa-heart text-danger"></i> Danh sách Yêu thích (@Model.Count() sản phẩm)</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <h4>Bạn chưa có sản phẩm yêu thích nào</h4>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Khám phá ngay</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        @if (item.Product != null && !string.IsNullOrEmpty(item.Product.ImageUrl))
                        {
                            <img src="@item.Product.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />
                        }
                        <div class="card-body">
                            <h5 class="card-title">@(item.Product?.Name ?? "Không tìm thấy sản phẩm")</h5>
                            <p class="text-muted">@(item.Product?.Code ?? "")</p>
                            <h5 class="text-primary">@(item.Product?.CurrentPrice.ToString("N0") ?? "0") ₫</h5>
                        </div>
                        <div class="card-footer">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                               class="btn btn-primary btn-sm">Xem chi tiết</a>
                            <form asp-action="Remove" method="post" style="display:inline;">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                        onclick="return confirm('Xóa khỏi Wishlist?')">
                                    Xóa
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>