@model PersonalInvestmentSystem.Web.Domain.Entities.Wallet
@{
    ViewData["Title"] = "Ví của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h3><i class="fas fa-wallet"></i> Ví Đầu tư Cá nhân</h3>
                </div>
                <div class="card-body text-center py-5">
                    <h1 class="display-4 text-success fw-bold">
                        @ViewBag.Balance.ToString("N0") ₫
                    </h1>
                    <p class="text-muted">Số dư hiện tại (VND)</p>
                    <div class="mt-4">
                        <a asp-controller="Payment" asp-action="Deposit" class="btn btn-primary btn-lg px-5">
                            <i class="fas fa-plus-circle"></i> Nạp tiền qua MoMo
                        </a>
                    </div>

                    <div class="mt-4">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-success btn-lg px-5">
                            <i class="fas fa-shopping-cart"></i> Mua sản phẩm ngay
                        </a>
                    </div>
                </div>
                <div class="card-footer text-center text-muted">
                    Cập nhật lần cuối: @Model?.UpdatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có giao dịch"
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">← Quay về Trang chủ</a>
            </div>
        </div>
    </div>
</div>