<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvestPro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fas fa-chart-line"></i> InvestPro
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Portfolio" asp-action="Index">Danh mục của tôi</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Wallet" asp-action="Index">Ví của tôi</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Transaction" asp-action="History">Giao dịch</a></li>
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown me-3">
                            <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-bell fa-lg"></i>
                                <span id="notificationCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.75rem; padding: 2px 6px;">
                                    0
                                </span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" style="width: 340px; max-height: 480px; overflow-y: auto;" id="notificationList">
                                <li class="dropdown-header fw-bold text-center">Thông báo</li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                Xin chào, @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Wallet" asp-action="Index">Ví của tôi</a></li>
                                <li><a class="dropdown-item" asp-controller="Portfolio" asp-action="Index">Danh mục đầu tư</a></li>
                                <li><a class="dropdown-item" asp-controller="Transaction" asp-action="History">Lịch sử giao dịch</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                        <button type="submit" class="dropdown-item text-danger border-0 bg-transparent">Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>@RenderBody()</main>

    <footer class="bg-dark text-white py-5 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5>InvestPro - Quản lý Đầu tư Cá nhân</h5>
                    <p>Hệ thống giúp bạn theo dõi danh mục đầu tư một cách minh bạch và an toàn.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p>&copy; 2026 Personal Investment System. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <text>
                // ==================== HÀM LOAD THÔNG BÁO TỪ DATABASE ====================
                async function loadNotifications() {
                    console.log("🔄 Đang tải thông báo từ Database...");
                    try {
                        const response = await fetch('/Notification/GetNotifications');
                        if (!response.ok) throw new Error('Lỗi khi gọi API');

                        const data = await response.json();
                        console.log("📥 Dữ liệu thông báo:", data);

                        const list = document.getElementById("notificationList");
                        const countEl = document.getElementById("notificationCount");

                        // Xóa thông báo cũ (giữ lại tiêu đề)
                        while (list.children.length > 1) {
                            list.removeChild(list.lastChild);
                        }

                        countEl.innerText = data.unreadCount || 0;

                        if (data.notifications && data.notifications.length > 0) {
                            data.notifications.forEach(noti => {
                                const item = document.createElement("li");
                                item.className = "dropdown-item border-bottom py-2";
                                item.innerHTML = `
                                    <strong>${noti.title}</strong><br>
                                    <small class="text-muted">${noti.message}</small><br>
                                    <small class="text-muted">${noti.createdDate}</small>
                                `;
                                list.appendChild(item);
                            });
                        } else {
                            const empty = document.createElement("li");
                            empty.className = "dropdown-item text-center text-muted py-3";
                            empty.textContent = "Không có thông báo nào";
                            list.appendChild(empty);
                        }
                    } catch (error) {
                        console.error("❌ Lỗi loadNotifications:", error);
                    }
                }

                // ==================== SIGNALR REALTIME ====================
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/notificationHub")
                    .withAutomaticReconnect()
                    .build();

                connection.on("ReceiveNotification", (title, message) => {
                    console.log("🔔 Nhận thông báo realtime:", title, message);

                    let countEl = document.getElementById("notificationCount");
                    let count = parseInt(countEl.innerText) || 0;
                    countEl.innerText = count + 1;

                    const list = document.getElementById("notificationList");
                    const item = document.createElement("li");
                    item.className = "dropdown-item border-bottom py-2";
                    item.innerHTML = `
                        <strong>${title}</strong><br>
                        <small class="text-muted">${message}</small><br>
                        <small class="text-muted">${new Date().toLocaleTimeString('vi-VN')}</small>
                    `;
                    list.appendChild(item);

                    // Toast thông báo
                    const toast = document.createElement('div');
                    toast.className = 'toast show position-fixed bottom-0 end-0 m-3 bg-success text-white';
                    toast.style.minWidth = '320px';
                    toast.style.zIndex = '9999';
                    toast.innerHTML = `
                        <div class="toast-header bg-success text-white">
                            <i class="fas fa-bell me-2"></i>
                            <strong>${title}</strong>
                            <button type="button" class="btn-close btn-close-white" onclick="this.parentElement.parentElement.remove()"></button>
                        </div>
                        <div class="toast-body">${message}</div>
                    `;
                    document.body.appendChild(toast);
                    setTimeout(() => toast.remove(), 7000);
                });

                connection.start()
                    .then(() => {
                        console.log("✅ SignalR Connected");
                        loadNotifications();   // ← Gọi hàm load thông báo từ DB
                    })
                    .catch(err => console.error("❌ SignalR Error:", err));
            </text>
        }
    </script>
</body>
</html>