<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvestPro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fas fa-chart-line"></i> InvestPro
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Portfolio" asp-action="Index">Danh mục của tôi</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Wallet" asp-action="Index">Ví của tôi</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Transaction" asp-action="History">Giao dịch</a></li>

                    <!-- Nút Wishlist -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="WatchList" asp-action="Index">
                            <i class="fas fa-heart"></i> Yêu thích
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Notification Bell -->
                        <li class="nav-item dropdown me-3">
                            <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-bell fa-lg"></i>
                                <span id="notificationCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.75rem; padding: 2px 6px;">
                                    0
                                </span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" style="width: 340px; max-height: 480px; overflow-y: auto;" id="notificationList">
                                <li class="dropdown-header fw-bold text-center">Thông báo</li>
                            </ul>
                        </li>

                        <!-- User Menu -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                Xin chào, @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Wallet" asp-action="Index">Ví của tôi</a></li>
                                <li><a class="dropdown-item" asp-controller="Portfolio" asp-action="Index">Danh mục đầu tư</a></li>
                                <li><a class="dropdown-item" asp-controller="WatchList" asp-action="Index">Danh sách yêu thích</a></li>
                                <li><a class="dropdown-item" asp-controller="Transaction" asp-action="History">Lịch sử giao dịch</a></li>
                                <li>
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "" )"
                                       href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
                                        <i class="fas fa-home"></i>
                                        <span class="link-text">Dashboard</span>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                        <button type="submit" class="dropdown-item text-danger border-0 bg-transparent">Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>@RenderBody()</main>

    <footer class="bg-dark text-white py-5 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5>InvestPro - Quản lý Đầu tư Cá nhân</h5>
                    <p>Hệ thống giúp bạn theo dõi danh mục đầu tư một cách minh bạch và an toàn.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p>&copy; 2026 Personal Investment System. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <text>
                // ... (giữ nguyên code SignalR và loadNotifications của bạn)
            </text>
        }
    </script>
</body>
</html>