<!DOCTYPE html>

<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Admin Panel</title>

    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            overflow-x: hidden;
        }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: #1e293b;
            transition: all 0.3s;
        }

            .sidebar.collapsed {
                width: 80px;
            }

            .sidebar .nav-link {
                color: #cbd5e1;
                padding: 12px 15px;
                border-radius: 10px;
                margin-bottom: 5px;
                display: flex;
                align-items: center;
                gap: 10px;
                transition: 0.2s;
            }

                .sidebar .nav-link:hover {
                    background: #334155;
                    color: #fff;
                }

                .sidebar .nav-link.active {
                    background: #2563eb;
                    color: white;
                    font-weight: 500;
                }

                .sidebar .nav-link i {
                    width: 20px;
                    text-align: center;
                }

            .sidebar.collapsed .link-text {
                display: none;
            }

        .content {
            flex-grow: 1;
            transition: all 0.3s;
        }

        .topbar {
            height: 60px;
        }
    </style>
    

</head>
<body>

    <div class="d-flex">

        
        <!-- SIDEBAR -->
        <div id="sidebar" class="sidebar p-3 text-white">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="mb-0">
                    <i class="fas fa-chart-line"></i>
                    <span class="link-text">Admin</span>
                </h5>
                <button class="btn btn-sm btn-light" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
            </div>

            <ul class="nav flex-column">

                <!-- Dashboard -->
                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "" )"
                       href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
                        <i class="fas fa-home"></i>
                        <span class="link-text">Dashboard</span>
                    </a>
                </li>

                <!-- Product -->
                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"
                       href="@Url.Action("Index", "Product", new { area = "Admin" })">
                        <i class="fas fa-box"></i>
                        <span class="link-text">Sản phẩm</span>
                    </a>
                </li>

                <!-- Create Product -->
                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
                       asp-area="Admin" asp-controller="Product" asp-action="Create">
                        <i class="fas fa-plus"></i>
                        <span class="link-text">Thêm sản phẩm</span>
                    </a>
                </li>

                <!-- Transactions -->
                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transaction" ? "active" : "")"
                       asp-area="Admin" asp-controller="Transaction" asp-action="Index">
                        <i class="fas fa-exchange-alt"></i>
                        <span class="link-text">Giao dịch</span>
                    </a>
                </li>

                <!-- Users -->
                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")"
                       asp-area="Admin" asp-controller="User" asp-action="Index">
                        <i class="fas fa-users"></i>
                        <span class="link-text">Người dùng</span>
                    </a>
                </li>

                <!-- Logout -->
                <li class="mt-3">
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="nav-link text-danger border-0 bg-transparent w-100 text-start">
                            <i class="fas fa-sign-out-alt"></i>
                            <span class="link-text">Đăng xuất</span>
                        </button>
                    </form>
                </li>

            </ul>
        </div>

        <!-- CONTENT -->
        <div class="content">

            <!-- TOPBAR -->
            <nav class="navbar navbar-light bg-light border-bottom px-4 topbar">
                <h5 class="mb-0">@ViewBag.Title</h5>
                <div class="ms-auto">
                    Xin chào, <strong>@User.Identity.Name</strong>
                </div>
            </nav>

            <!-- MAIN -->
            <div class="p-4">
                @RenderBody()
            </div>

        </div>
        

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("collapsed");
        }
    </script>

</body>
</html>
