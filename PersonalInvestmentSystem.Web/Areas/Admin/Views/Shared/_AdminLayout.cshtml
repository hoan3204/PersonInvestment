<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        .sidebar { min-height: 100vh; background: #343a40; }
        .nav-link { color: #adb5bd; }
        .nav-link:hover, .nav-link.active { color: white; background: #495057; }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="sidebar p-3 text-white" style="width: 260px;">
            <h4 class="text-center mb-4"><i class="fas fa-chart-line"></i> Investment Admin</h4>
            <ul class="nav flex-column">
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="fas fa-home"></i> Dashboard</a></li>
                <li class="nav-item"><a class="nav-link active" asp-area="Admin" asp-controller="Product" asp-action="Index"><i class="fas fa-box"></i> Quản lý Sản phẩm</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="fas fa-users"></i> Quản lý Người dùng</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="fas fa-exchange-alt"></i> Giao dịch</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="fas fa-newspaper"></i> Tin tức</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a></li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="flex-grow-1">
            <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom px-4">
                <h5>@ViewBag.Title</h5>
                <div class="ms-auto">
                    Xin chào, <strong>Admin</strong>
                </div>
            </nav>
            <div class="p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>