@model IEnumerable<PersonalInvestmentSystem.Web.Domain.Entities.AppUser>
@{
    ViewBag.Title = "Quản lý Người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3><i class="fas fa-users"></i> Quản lý Người dùng</h3>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Số điện thoại</th>
            <th>Ngày sinh</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.PhoneNumber</td>
                <td>@user.DateOfBirth.ToString("dd/MM/yyyy")</td>
                <td>
                    <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">
                        @(user.IsActive ? "Hoạt động" : "Khóa")
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Chi tiết</a>
                </td>
            </tr>
        }
    </tbody>
</table>