@model IEnumerable<PersonalInvestmentSystem.Web.Domain.Entities.Transaction>
@{
    ViewBag.Title = "Quản lý Giao dịch";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3><i class="fas fa-exchange-alt"></i> Quản lý Giao dịch</h3>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Thời gian</th>
            <th>Người dùng</th>
            <th>Sản phẩm</th>
            <th>Loại</th>
            <th>Số lượng</th>
            <th>Giá</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@t.User?.FullName</td>
                <td>@t.Product?.Name</td>
                <td>
                    <span class="badge @(t.Type == PersonalInvestmentSystem.Web.Domain.Enums.TransactionType.Buy ? "bg-success" : "bg-danger")">
                        @(t.Type == PersonalInvestmentSystem.Web.Domain.Enums.TransactionType.Buy ? "MUA" : "BÁN")
                    </span>
                </td>
                <td class="text-end">@t.Quantity</td>
                <td class="text-end">@t.Price.ToString("N0") ₫</td>
                <td class="text-end fw-bold">@t.TotalAmount.ToString("N0") ₫</td>
                <td>
                    <span class="badge bg-success">@t.Status</span>
                </td>
            </tr>
        }
    </tbody>
</table>