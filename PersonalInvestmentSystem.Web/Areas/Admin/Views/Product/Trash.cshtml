@model PersonalInvestmentSystem.Web.ViewModels.Product.PagedResult<PersonalInvestmentSystem.Web.Domain.Entities.InvestmentProduct>
@{
    ViewBag.Title = "Thùng rác Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">Thùng rác Sản phẩm</h3>
        <small class="text-muted">Sản phẩm bị xóa mềm sẽ tự động xóa vĩnh viễn sau <strong>@ViewBag.RetentionDays</strong> ngày.</small>
    </div>
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại danh sách
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form asp-action="Trash" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm theo tên/mã..." />
        <button class="btn btn-outline-primary" type="submit">Tìm</button>
    </div>
</form>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Mã</th>
            <th>Tên sản phẩm</th>
            <th>Giá hiện tại</th>
            <th>Ngày xóa</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Items.Any())
        {
            <tr>
                <td colspan="5" class="text-center text-muted">Thùng rác trống.</td>
            </tr>
        }
        else
        {
            @foreach (var p in Model.Items)
            {
                <tr>
                    <td><strong>@p.Code</strong></td>
                    <td>@p.Name</td>
                    <td class="text-end">@p.CurrentPrice.ToString("N0") ₫</td>
                    <td>@(p.DeleteDate?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                    <td>
                        <form asp-area="Admin" asp-controller="Product" asp-action="Restore" asp-route-id="@p.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-success">Khôi phục</button>
                        </form>
                        <form asp-area="Admin" asp-controller="Product" asp-action="DeletePermanent" asp-route-id="@p.Id" method="post" style="display:inline;" onsubmit="return confirm('Xóa vĩnh viễn sản phẩm này?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Xóa vĩnh viễn</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Trash" asp-route-page="@i" asp-route-search="@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}