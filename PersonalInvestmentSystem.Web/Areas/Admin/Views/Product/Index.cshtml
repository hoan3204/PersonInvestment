@model PersonalInvestmentSystem.Web.ViewModels.Product.PagedResult<PersonalInvestmentSystem.Web.Domain.Entities.InvestmentProduct>
@{
    ViewBag.Title = "Quản lý Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between mb-4">
    <h3>Quản lý Sản phẩm Đầu tư</h3>
    <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-success" ><i class="fas fa-plus"></i> Thêm mới</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Mã</th>
            <th>Tên sản phẩm</th>
            <th>Loại</th>
            <th>Giá hiện tại</th>
            <th>% Thay đổi</th>
            <th>Rủi ro</th>
            <th>Nổi bật</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Items)
        {
            <tr>
                <td><strong>@p.Code</strong></td>
                <td>@p.Name</td>
                <td>@p.Type</td>
                <td class="text-end">@p.CurrentPrice.ToString("N0") ₫</td>
                <td class="@(p.ChangePercent >= 0 ? "text-success" : "text-danger")">@p.ChangePercent %</td>
                <td>@p.RiskLevel</td>
                <td class="text-center">@(p.IsFeatured ? "✅" : "")</td>
                <td>@(p.IsActive ? "Hoạt động" : "Tạm ngừng")</td>
                <td>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-primary">Sửa</a>
                    <form asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline;" onsubmit="return confirm('Xóa sản phẩm này?')">
                        <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>