@model PersonalInvestmentSystem.Web.Domain.Entities.InvestmentProduct
@{
    ViewBag.Title = "Thêm Sản phẩm Mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h5><i class="fas fa-plus"></i> Thêm Sản phẩm Đầu tư Mới</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Mã sản phẩm</label>
                        <input asp-for="Code" class="form-control" required />
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="row">
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Loại sản phẩm</label>
                        <select asp-for="Type" class="form-select" asp-items="ViewBag.Types" required>
                            <option value="">-- Chọn loại --</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Danh mục</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" required></select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Nhà phát hành</label>
                        <select asp-for="PublisherId" class="form-select" asp-items="ViewBag.Publishers" required></select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Hình ảnh</label>
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label">Giá hiện tại (₫)</label>
                        <input asp-for="CurrentPrice" type="number" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label">Giá trước đó (₫)</label>
                        <input asp-for="PreviousPrice" type="number" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label">Mức rủi ro</label>
                        <select asp-for="RiskLevel" class="form-select" asp-items="ViewBag.RiskLevels" required></select>
                    </div>
                </div>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsFeatured" type="checkbox" class="form-check-input" />
                <label asp-for="IsFeatured" class="form-check-label">Sản phẩm nổi bật</label>
            </div>

            <div class="form-check mb-4">
                <input asp-for="IsActive" type="checkbox" class="form-check-input" checked />
                <label asp-for="IsActive" class="form-check-label">Đang hoạt động</label>
            </div>

            <button type="submit" class="btn btn-primary">Thêm sản phẩm</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>